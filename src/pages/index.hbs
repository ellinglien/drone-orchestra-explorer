<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>DRONE ORCHESTRA EXPLORER</title>
    <script src="https://aframe.io/releases/1.2.0/aframe.min.js"></script>
    <style>
        #startButton {
            position: absolute;
            z-index: 9999;
            top: 10px;
            left: 10px;
            padding: 10px 20px;
            font-size: 16px;
            cursor: pointer;
            display: none; /* Initially hide the start button */
        }
    </style>
</head>
<body>
    <button id="startButton">START</button>
    <a-scene>
        <a-assets>
            <!-- Audio files setup for streaming with minimal preload -->
            <audio id="drone1" src="/audio/00001drone.ogg" preload="metadata"></audio>
            <audio id="drone2" src="/audio/00002drone.ogg" preload="metadata"></audio>
            <audio id="drone3" src="/audio/00003drone.ogg" preload="metadata"></audio>
            <audio id="drone4" src="/audio/00004drone.ogg" preload="metadata"></audio>
            <audio id="drone5" src="/audio/00005drone.ogg" preload="metadata"></audio>
            <audio id="drone6" src="/audio/00006drone.ogg" preload="metadata"></audio>
            <audio id="drone7" src="/audio/00007drone.ogg" preload="metadata"></audio>
            <audio id="drone8" src="/audio/00008drone.ogg" preload="metadata"></audio>
            <audio id="drone9" src="/audio/00009drone.ogg" preload="metadata"></audio>
            <audio id="drone10" src="/audio/00010drone.ogg" preload="metadata"></audio>
        </a-assets>
        <a-entity camera look-controls wasd-controls="acceleration: 5; easing: 20" position="0 1.6 0"></a-entity>
    </a-scene>

    <script>
        var button = document.getElementById('startButton');
        document.querySelector('a-scene').addEventListener('loaded', function () {
            button.style.display = 'block';
        });

        button.addEventListener('click', function () {
            var sceneEl = document.querySelector('a-scene');
            var assets = document.querySelectorAll('audio');
            var isPlaying = button.textContent === 'STOP';

            if (!isPlaying) {
                for (let i = 1; i <= assets.length; i++) {
                    let audioId = `drone${i}`;
                    let audioEl = document.getElementById(audioId);
                    let entityEl = document.createElement('a-entity');
                    entityEl.setAttribute('sound', `src: #${audioId}; positional: true; refDistance: 1; rolloffFactor: 1.5; loop: true;`);
                    sceneEl.appendChild(entityEl);
                    audioEl.play();
                }
                button.textContent = 'STOP';
            } else {
                assets.forEach(audio => {
                    audio.pause();
                    audio.currentTime = 0;
                });
                sceneEl.querySelectorAll('[sound]').forEach(el => {
                    el.parentNode.removeChild(el);
                });
                button.textContent = 'START';
            }
        });
    </script>
</body>
</html>