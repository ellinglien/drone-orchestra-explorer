<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>DRONE ORCHESTRA</title>
    <script src="https://aframe.io/releases/1.2.0/aframe.min.js"></script>
    <!-- Include A-Frame Extras for enhanced movement controls -->
    <script src="https://unpkg.com/aframe-extras@6/dist/aframe-extras.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/aframe-physics-system/dist/aframe-physics-system.min.js"></script>
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            font-family: 'Arial', sans-serif;
        }
        
        #intro-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.9);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }
        
        #title {
            font-size: 80px;
            font-weight: bold;
            color: #FFF;
            margin-bottom: 60px;
            text-align: center;
            letter-spacing: 10px;
        }
        
        #startButton {
            padding: 15px 30px;
            font-size: 18px;
            background-color: #330000;
            color: white;
            border: none;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        #startButton:hover {
            background-color: #990000;
            transform: scale(1.05);
        }
        
        #controls {
            color: white;
            margin-top: 40px;
            text-align: center;
            max-width: 600px;
            line-height: 1.6;
        }
        
        #brightness-controls {
            position: absolute;
            z-index: 9998;
            bottom: 20px;
            right: 20px;
            background-color: rgba(0, 0, 0, 0.6);
            padding: 10px;
            border-radius: 5px;
            color: white;
            display: none;
        }
        
        .slider-container {
            display: flex;
            align-items: center;
            margin-bottom: 10px;
        }
        
        .slider-container label {
            margin-right: 10px;
            width: 100px;
        }
        
        input[type="range"] {
            width: 150px;
        }
    </style>
  
    <script>
        AFRAME.registerComponent('flight-controls', {
            schema: {
                speed: {type: 'number', default: 10},
                acceleration: {type: 'number', default: 50},
                easing: {type: 'number', default: 0.5}, // This controls the 'inertia' or 'momentum'
                friction: {type: 'number', default: 0.05} // Friction to slowly stop the movement
            },
            init: function() {
                this.velocity = new THREE.Vector3(0, 0, 0);
                this.direction = new THREE.Vector3(0, 0, 0);
                this.keys = {};
                window.addEventListener('keydown', (event) => this.onKeyDown(event));
                window.addEventListener('keyup', (event) => this.onKeyUp(event));
            },
            onKeyDown: function(event) {
                this.keys[event.code] = true;
            },
            onKeyUp: function(event) {
                this.keys[event.code] = false;
            },
            tick: function(time, timeDelta) {
                const data = this.data;
                const acceleration = new THREE.Vector3(0, 0, 0);
                const cameraWorldQuaternion = new THREE.Quaternion();
                this.el.object3D.getWorldQuaternion(cameraWorldQuaternion);

                // Apply acceleration based on key press
                if (this.keys['KeyW']) acceleration.z -= data.acceleration;
                if (this.keys['KeyS']) acceleration.z += data.acceleration;
                if (this.keys['KeyA']) acceleration.x -= data.acceleration;
                if (this.keys['KeyD']) acceleration.x += data.acceleration;
                acceleration.applyQuaternion(cameraWorldQuaternion);
                acceleration.multiplyScalar(timeDelta / 1000);

                // Update velocity with the new acceleration
                this.velocity.add(acceleration);

                // Apply friction to simulate momentum and zero gravity effect
                this.velocity.multiplyScalar(1 - data.friction);

                // Update position based on velocity
                const positionDelta = this.velocity.clone().multiplyScalar(timeDelta / 1000);
                this.el.object3D.position.add(positionDelta);
            }
        });

        AFRAME.registerComponent('brightness-control', {
            schema: {
                brightness: {type: 'number', default: 0.5},  
                opacity: {type: 'number', default: 1.0}
            },
            init: function() {
                this.entities = [];
            },
            update: function() {
                const data = this.data;
                const entities = document.querySelectorAll('.drone-entity');
                
                this.entities = Array.from(entities);
                
                this.entities.forEach(entity => {
                    const polyhedron = entity.querySelector('.drone-object');
                    if (polyhedron) {
                        // Calculate color based on brightness
                        const brightness = data.brightness;
                        const r = Math.floor(26 + brightness * 100);
                        const g = Math.floor(0 + brightness * 30);
                        const b = Math.floor(0 + brightness * 30);
                        const color = `rgb(${r}, ${g}, ${b})`;
                        
                        polyhedron.setAttribute('material', `color: ${color}; side: double; transparent: true; opacity: ${data.opacity}`);
                    }
                });
            }
        });

        // Create orbital animation component
        AFRAME.registerComponent('orbital-motion', {
            schema: {
                radius: {type: 'number', default: 5},
                speed: {type: 'number', default: 1},
                inclination: {type: 'number', default: 0},
                azimuthalOffset: {type: 'number', default: 0},
                direction: {type: 'number', default: 1}, // 1 for counter-clockwise, -1 for clockwise
                tilt: {type: 'number', default: 0}, // Orbital plane tilt
                eccentricity: {type: 'number', default: 0} // Elliptical orbit (0 = circular)
            },
            init: function() {
                this.time = 0;
            },
            tick: function(time, timeDelta) {
                const data = this.data;
                this.time += timeDelta / 1000;
                
                // Calculate angle based on speed and direction
                const angle = this.time * data.speed * data.direction + data.azimuthalOffset;
                
                // Calculate radius with eccentricity for elliptical orbits
                const radius = data.radius * (1 - data.eccentricity * Math.cos(angle));
                
                // Calculate position
                let x = radius * Math.cos(angle);
                let y = radius * Math.sin(angle);
                let z = 0;
                
                // Apply inclination (tilt the orbit plane)
                const cosInc = Math.cos(data.inclination);
                const sinInc = Math.sin(data.inclination);
                const newY = y * cosInc - z * sinInc;
                const newZ = y * sinInc + z * cosInc;
                y = newY;
                z = newZ;
                
                // Apply orbital plane tilt
                const cosTilt = Math.cos(data.tilt);
                const sinTilt = Math.sin(data.tilt);
                const newX = x * cosTilt - z * sinTilt;
                const finalZ = x * sinTilt + z * cosTilt;
                x = newX;
                z = finalZ;
                
                this.el.setAttribute('position', `${x} ${y} ${z}`);
            }
        });
    </script>
</head>
<body>
    <div id="intro-overlay">
        <div id="title">DRONE ORCHESTRA</div>
        <button id="startButton">THERE'S NO GOING BACK</button>
        <div id="controls">
            <p><strong>CONTROLS:</strong></p>
            <p>MOVEMENT: W (forward), S (backward), A (left), D (right)</p>
            <p>LOOK: Mouse to look around</p>
            <p>BRIGHTNESS: Use sliders that appear at the bottom right after starting</p>
            <p>For the full experience, use headphones.</p>
        </div>
    </div>

    <div id="brightness-controls">
        <div class="slider-container">
            <label for="brightness">Brightness:</label>
            <input type="range" id="brightness" min="0" max="10" value="5" step="0.1">
        </div>
        <div class="slider-container">
            <label for="opacity">Opacity:</label>
            <input type="range" id="opacity" min="0" max="10" value="10" step="0.1">
        </div>
    </div>

    <a-scene background="color: black">
        <a-assets>
            <!-- Preload the audio files -->
            <!-- Audio files setup for streaming with minimal preload -->
            <audio id="drone1" src="https://cdn.glitch.global/01909728-80f3-4f8c-96f4-8e8d054cfc08/public%2Faudio%2FUSTAKNOW_ALIAS_CR05APR2025__CHAOS_DRONE_STEM__ForAprilREMDroneOrchestraCompilationMix_.ogg" preload="metadata"></audio>
            <audio id="drone2" src="https://cdn.glitch.global/01909728-80f3-4f8c-96f4-8e8d054cfc08/public%2FHogardApr25dronebongo.ogg" preload="metadata"></audio>
            <audio id="drone3" src="https://cdn.glitch.global/01909728-80f3-4f8c-96f4-8e8d054cfc08/kerning%20man%20april%20chaos%20drone.ogg" preload="metadata"></audio>
            <audio id="drone4" src="https://cdn.glitch.global/01909728-80f3-4f8c-96f4-8e8d054cfc08/ohnonotagain-april2025.ogg" preload="metadata"></audio>
            <audio id="drone5" src="https://cdn.glitch.global/01909728-80f3-4f8c-96f4-8e8d054cfc08/AMUC-Chaotic-Drone-April-2025.ogg" preload="metadata"></audio>
            <audio id="drone6" src="https://cdn.glitch.global/01909728-80f3-4f8c-96f4-8e8d054cfc08/Kessler-Chaotic-Drone-April-2025.ogg" preload="metadata"></audio>
            <audio id="drone7" src="https://cdn.glitch.global/01909728-80f3-4f8c-96f4-8e8d054cfc08/jai_DroneOrchestraAvril.ogg" preload="metadata"></audio>
            <audio id="drone8" src="https://cdn.glitch.global/01909728-80f3-4f8c-96f4-8e8d054cfc08/Metamere%20-%20Drone%20Orchestra%202025-04%20-%20MODOK.ogg" preload="metadata"></audio>
            <audio id="drone9" src="https://cdn.glitch.global/01909728-80f3-4f8c-96f4-8e8d054cfc08/Mikey%20-%20Drone%20Orchestra%20Apr%2025%20Chaos.ogg" preload="metadata"></audio>
            <audio id="drone10" src="https://cdn.glitch.global/01909728-80f3-4f8c-96f4-8e8d054cfc08/CyberneticVoyagerApril2025Chaos.ogg" preload="metadata"></audio>
            <audio id="drone11" src="https://cdn.glitch.global/01909728-80f3-4f8c-96f4-8e8d054cfc08/Coyote%20Senate%20Drone%20Orchestra%20April%202025.ogg" preload="metadata"></audio>
        </a-assets>
        
        <!-- Camera with enhanced movement controls -->
        <a-entity camera look-controls="pointerLockEnabled: true" flight-controls="speed: 7; acceleration: 5; easing: 9" position="0 1.6 0" smooth-look-controls="dampingFactor: 1"></a-entity>

        <!-- Example Cube -->
        <a-box id="targetCube" position="0 0 -5" depth="1" height="0" width="0" color="none"></a-box>
        
        <!-- Add brightness control component to the scene -->
        <a-entity id="brightness-control-entity" brightness-control="brightness: 0.5; opacity: 1.0"></a-entity>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const cameraEl = document.querySelector('[camera]');
                const cubeEl = document.getElementById('targetCube');

                // Calculate a position for the camera: This positions the camera 10 units away from the cube, directly in front of it.
                let cubePos = cubeEl.object3D.position;
                let offset = new THREE.Vector3(0, 0, 10);  // You can adjust this vector to change the distance and angle.
                let cameraPos = cubePos.clone().add(offset);

                // Set the camera's position and orient it to look at the cube
                cameraEl.setAttribute('position', cameraPos);
                cameraEl.setAttribute('look-at', `#${cubeEl.id}`);
            });
        </script>
    </a-scene>

    <script>
        document.getElementById('startButton').addEventListener('click', function () {
            // Hide intro overlay
            document.getElementById('intro-overlay').style.display = 'none';
            // Show brightness controls
            document.getElementById('brightness-controls').style.display = 'block';
            
            var sceneEl = document.querySelector('a-scene');
            const primitives = ['box']; // Polyhedron types
            const numberOfEntities = 10;
            const randomImmediateIndex = Math.floor(Math.random() * numberOfEntities); // Select one random index for immediate load

            for (let i = 0; i < numberOfEntities; i++) {
                let audioId = `drone${i + 1}`;

                let entityEl = document.createElement('a-entity');
                entityEl.setAttribute('class', 'drone-entity');

                // Generate random orbital parameters for each drone
                const radius = 3 + Math.random() * 7; // Orbit radius between 3 and 10
                const speed = 0.05 + Math.random() * 0.1; // Speed of orbit
                const inclination = Math.PI * (Math.random() * 0.5 - 0.25); // Inclination angle
                const azimuthalOffset = Math.PI * 2 * Math.random(); // Starting position on orbit
                const direction = Math.random() > 0.5 ? 1 : -1; // Random direction
                const tilt = Math.PI * (Math.random() * 0.5 - 0.25); // Orbital plane tilt
                const eccentricity = Math.random() * 0.3; // Elliptical orbit

                // Apply orbital motion component
                entityEl.setAttribute('orbital-motion', {
                    radius: radius,
                    speed: speed,
                    inclination: inclination,
                    azimuthalOffset: azimuthalOffset,
                    direction: direction,
                    tilt: tilt,
                    eccentricity: eccentricity
                });

                let primitiveType = primitives[Math.floor(Math.random() * primitives.length)];
                let polyhedronEl = document.createElement('a-entity');
                polyhedronEl.setAttribute('geometry', `primitive: ${primitiveType}; radius: 0.5; detail: 0`);
                polyhedronEl.setAttribute('material', 'color: #1a0000; side: double; transparent: true; opacity: 0');
                polyhedronEl.setAttribute('visible', 'false');
                polyhedronEl.setAttribute('class', 'drone-object');

                let initialRotation = {x: Math.random() * 360, y: Math.random() * 360, z: Math.random() * 360};
                polyhedronEl.setAttribute('rotation', `${initialRotation.x} ${initialRotation.y} ${initialRotation.z}`);

                let scaleMin = 0.8 + Math.random() * 0.7;
                let scaleMax = 2.0 + Math.random();
                let duration = 20000 + Math.random() * 4000;
                let delay = i === randomImmediateIndex ? 0 : Math.random() * 100000 + 1000; // Immediate for the selected index, random delay for others

                setTimeout(() => {
                    polyhedronEl.setAttribute('visible', 'true');
                    polyhedronEl.setAttribute('animation__opacity', `property: material.opacity; from: 0; to: 1; dur: 10000; easing: easeInOutQuad`);
                    entityEl.setAttribute('sound', `src: #${audioId}; autoplay: true; positional: true; refDistance: 1; rolloffFactor: 1.5; loop: true;`);
                    
                    // Update the brightness control to affect the new entity
                    let brightnessControlEntity = document.getElementById('brightness-control-entity');
                    let component = brightnessControlEntity.components['brightness-control'];
                    if (component) {
                        component.update();
                    }
                }, delay);

                entityEl.appendChild(polyhedronEl);
                sceneEl.appendChild(entityEl);
            }
        });

        // Set up brightness and opacity sliders
        document.getElementById('brightness').addEventListener('input', function(e) {
            const value = e.target.value / 10; // Convert 0-10 to 0-1
            const brightnessControlEntity = document.getElementById('brightness-control-entity');
            const opacityValue = document.getElementById('opacity').value / 10;
            brightnessControlEntity.setAttribute('brightness-control', `brightness: ${value}; opacity: ${opacityValue}`);
        });

        document.getElementById('opacity').addEventListener('input', function(e) {
            const value = e.target.value / 10; // Convert 0-10 to 0-1
            const brightnessControlEntity = document.getElementById('brightness-control-entity');
            const brightnessValue = document.getElementById('brightness').value / 10;
            brightnessControlEntity.setAttribute('brightness-control', `brightness: ${brightnessValue}; opacity: ${value}`);
        });

        AFRAME.registerComponent('smooth-look-controls', {
            schema: {
                dampingFactor: { type: 'number', default: 0.5 },
                decayFactor: { type: 'number', default: 0.95 } // Control how quickly to reduce follow-through
            },
            init: function () {
                this.targetRotation = new THREE.Quaternion();
                this.currentRotation = new THREE.Quaternion();
                this.decay = 1.0; // Start with no reduction in damping
            },
            tick: function (time, timeDelta) {
                var data = this.data;
                var obj3D = this.el.object3D;
                var delta = (timeDelta / 1000) * data.dampingFactor * this.decay; // Apply decay to damping

                // Update decay factor, reducing the damping effect over time
                this.decay *= data.decayFactor;
                this.decay = Math.max(this.decay, 0.1); // Ensure decay does not reduce damping below a minimum threshold

                // Convert current and target to Quaternion to use slerp for smoothing
                this.targetRotation.copy(obj3D.quaternion);
                this.currentRotation.slerp(this.targetRotation, delta); // Spherical linear interpolation
                obj3D.quaternion.copy(this.currentRotation);
            }
        });
    </script>
</body>
</html>