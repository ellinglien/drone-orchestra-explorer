<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Interactive Drone Music Player</title>
    <script src="https://aframe.io/releases/1.2.0/aframe.min.js"></script>
    <style>
        #startButton {
            position: absolute;
            z-index: 9999;
            top: 10px;
            left: 10px;
            padding: 10px 20px;
            font-size: 16px;
            cursor: pointer;
            display: none; /* Initially hidden */
        }
    </style>
</head>
<body>
    <button id="startButton" disabled>Start Experience</button>
    <a-scene>
        <a-assets timeout="300000">
            <!-- Preload only the first audio file initially -->
            <audio id="drone1" src="https://road-excessive-belief.me/audio/00001drone.ogg" crossorigin="anonymous" preload="auto"></audio>
        </a-assets>

        <a-entity camera look-controls wasd-controls position="0 1.6 0"></a-entity>
    </a-scene>

    <script>
        document.querySelector('a-scene').addEventListener('loaded', function () {
            var button = document.getElementById('startButton');
            button.style.display = 'block'; // Show the button
            button.disabled = false; // Enable the button
            button.addEventListener('click', function () {
                loadDrones();
            });
        });

        function loadDrones() {
            var sceneEl = document.querySelector('a-scene');
            var radius = 10; // Radius of the circle
            var y = 1.6;   // Height of the audio sources
            for (let i = 2; i <= 10; i++) {
                setTimeout(function () {
                    let angle = (i / 10) * Math.PI * 2;
                    let x = Math.cos(angle) * radius;
                    let z = Math.sin(angle) * radius;
                    let audioId = `drone${i}`;
                    let audioSrc = `https://road-excessive-belief.glitch.me/audio/0000${String(i).padStart(2, '0')}drone.ogg`;
                    let audioEl = document.createElement('audio');
                    audioEl.setAttribute('id', audioId);
                    audioEl.setAttribute('src', audioSrc);
                    audioEl.setAttribute('crossorigin', 'anonymous');
                    document.body.appendChild(audioEl);

                    let entityEl = document.createElement('a-entity');
                    entityEl.setAttribute('position', `${x} ${y} ${z}`);
                    entityEl.setAttribute('sound', `src: #${audioId}; rolloffFactor: 1.5; refDistance: 1; maxDistance: 50;`);
                    sceneEl.appendChild(entityEl);
                }, i * 1000); // Delay loading each subsequent file to reduce load
            }
        }
    </script>
</body>
</html>
