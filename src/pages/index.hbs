<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Interactive Drone Music Player</title>
    <script src="https://aframe.io/releases/1.2.0/aframe.min.js"></script>
    <style>
        /* Ensure button is clickable by bringing it above the A-Frame canvas */
        #startButton {
            position: absolute;
            z-index: 9999;
            top: 10px;
            left: 10px;
            padding: 10px 20px;
            font-size: 16px;
            cursor: pointer;
        }
        /* Style for the loading bar */
        #loadingBar {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 300px;
            height: 30px;
            transform: translate(-50%, -50%);
            background: #eee;
            border: 2px solid #222;
            z-index: 10000; /* Make sure this is visible over other content */
        }
        #loadingBarInner {
            height: 100%;
            background: #4CAF50; /* Green color to indicate progress */
            width: 0%; /* Start with no progress */
        }
    </style>
</head>
<body>
    <button id="startButton">Start Experience</button>
    <div id="loadingBar">
        <div id="loadingBarInner"></div>
    </div>
    <a-scene>
        <a-assets>
            <!-- Audio files setup for streaming with minimal preload -->
            <audio id="drone1" src="/audio/00001drone.ogg" preload="metadata"></audio>
            <audio id="drone2" src="/audio/00002drone.ogg" preload="metadata"></audio>
            <audio id="drone3" src="/audio/00003drone.ogg" preload="metadata"></audio>
        </a-assets>
    </a-scene>

<script>
    document.getElementById('startButton').addEventListener('click', function () {
        var sceneEl = document.querySelector('a-scene');
        var assets = sceneEl.querySelectorAll('audio');
        var totalAssets = assets.length;
        var loadedAssets = 0;

        // Ensure each audio asset triggers loading
        assets.forEach(function (audio) {
            // Listener to update loading progress as data is available
            audio.addEventListener('loadeddata', function () {
                loadedAssets++;
                updateLoadingBar(loadedAssets, totalAssets);
                if (loadedAssets >= totalAssets) {
                    document.getElementById('loadingBar').style.display = 'none'; // Hide loading bar
                    startExperience(); // Function to start the experience
                }
            });
            audio.load(); // Explicitly call load to ensure the browser starts fetching data
        });
    });

    function updateLoadingBar(loaded, total) {
        var progress = (loaded / total) * 100;
        document.getElementById('loadingBarInner').style.width = progress + '%';
    }

    function startExperience() {
        var assets = document.querySelectorAll('audio');
        assets.forEach(audio => {
            audio.play(); // Play audio when ready
        });
        // Additional logic to start VR experience
    }
</script>
</body>
</html>