<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Interactive Drone Music Player</title>
    <script src="https://aframe.io/releases/1.2.0/aframe.min.js"></script>
    <style>
        /* Ensure button is clickable by bringing it above the A-Frame canvas */
        #startButton {
            position: absolute;  /* Position it relative to the viewport */
            z-index: 9999;       /* Higher z-index so it's above A-Frame canvas */
            top: 10px;           /* Margin from the top of the viewport */
            left: 10px;          /* Margin from the left of the viewport */
            padding: 10px 20px;  /* Padding for better appearance */
            font-size: 16px;     /* Larger font size for better readability */
            cursor: pointer;     /* Cursor indicates it's clickable */
        }
    </style>
</head>
<body>
    <button id="startButton">Start Experience</button>
    <a-scene>
        <a-assets timeout="300000">
            <!-- Preload the audio files -->
            <audio id="drone1" src="/audio/00001drone.ogg" preload="auto"></audio>
            <audio id="drone2" src="/audio/00002drone.ogg" preload="auto"></audio>
            <audio id="drone3" src="/audio/00003drone.ogg" preload="auto"></audio>
            <audio id="drone4" src="/audio/00004drone.ogg" preload="auto"></audio>
            <audio id="drone5" src="/audio/00005drone.ogg" preload="auto"></audio>
       

        </a-assets>

        <!-- Placeholder entities for the audio sources to be dynamically attached -->
    </a-scene>

    <script>
        document.getElementById('startButton').addEventListener('click', function () {
            var sceneEl = document.querySelector('a-scene');
            var radius = 5; // Reduced radius for closer audio source placement
            var y = 1.6;    // Height of the audio sources

            for (let i = 1; i <= 6; i++) {  // Updated to include all six audio files
                let angle = (i / 6) * Math.PI * 2; // Adjust loop to use 6
                let x = Math.cos(angle) * radius;
                let z = Math.sin(angle) * radius;
                let audioId = `drone${i}`;

                // Ensure audio elements are available
                let audioEl = document.getElementById(audioId);
                if (!audioEl.src) {
                    // Only set src if not already set
                    audioEl.src = `/audio/0000${i.toString().padStart(2, '0')}drone.ogg`;
                    audioEl.load(); // Force the browser to load the new source
                }

                // Create an entity for each audio source
                let entityEl = document.createElement('a-entity');
                entityEl.setAttribute('position', `${x} ${y} ${z}`);
                entityEl.setAttribute('sound', `src: #${audioId}; autoplay: true; positional: true; refDistance: 1; rolloffFactor: 1.5; loop: true;`);

                // Add a visual cube for each audio source
                let boxEl = document.createElement('a-box');
                boxEl.setAttribute('position', '0 0 0');
                boxEl.setAttribute('color', '#1a1a2e');
                boxEl.setAttribute('depth', '0.5');
                boxEl.setAttribute('height', '0.5');
                boxEl.setAttribute('width', '0.5');
                entityEl.appendChild(boxEl);

                sceneEl.appendChild(entityEl);
            }
        });
    </script>
</body>
</html>
