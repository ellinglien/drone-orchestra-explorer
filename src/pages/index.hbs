<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>DRONE EXPLOERE</title>
    <script src="https://aframe.io/releases/1.2.0/aframe.min.js"></script>
    <!-- Include A-Frame Extras for enhanced movement controls -->
    <script src="https://unpkg.com/aframe-extras@6/dist/aframe-extras.min.js"></script>
    <style>
        #startButton {
            position: absolute;
            z-index: 9999;
            top: 10px;
            left: 10px;
            padding: 10px 20px;
            font-size: 16px;
            cursor: pointer;
        }
    </style>
  
 <script>
  AFRAME.registerComponent('flight-controls', {
    schema: {
      speed: {type: 'number', default: 10},
      acceleration: {type: 'number', default: 20},
      easing: {type: 'number', default: 3} // Easing factor
    },
    init: function() {
      this.velocity = new THREE.Vector3(0, 0, 0);
      this.direction = new THREE.Vector3(0, 0, 0);
      this.keys = {};
      window.addEventListener('keydown', (event) => this.onKeyDown(event));
      window.addEventListener('keyup', (event) => this.onKeyUp(event));
    },
    onKeyDown: function(event) {
      this.keys[event.code] = true;
    },
    onKeyUp: function(event) {
      this.keys[event.code] = false;
    },
    tick: function(time, timeDelta) {
      const data = this.data;
      const acceleration = new THREE.Vector3(0, 0, 0);
      const cameraWorldQuaternion = new THREE.Quaternion();
      this.el.object3D.getWorldQuaternion(cameraWorldQuaternion);

      // Direction based on key press
      if (this.keys['KeyW']) acceleration.z -= data.acceleration;
      if (this.keys['KeyS']) acceleration.z += data.acceleration;
      if (this.keys['KeyA']) acceleration.x -= data.acceleration;
      if (this.keys['KeyD']) acceleration.x += data.acceleration;
      acceleration.applyQuaternion(cameraWorldQuaternion);
      acceleration.multiplyScalar(timeDelta / 1000);

      // Update velocity with easing
      this.velocity.add(acceleration);
      this.velocity.multiplyScalar(data.easing * timeDelta / 1000);

      // Update position
      const positionDelta = new THREE.Vector3(this.velocity.x, this.velocity.y, this.velocity.z);
      positionDelta.multiplyScalar(timeDelta / 1000);
      this.el.object3D.position.add(positionDelta);
    }
  });
</script>


</head>
<body>
    <button id="startButton">THERE'S NO GOING BACK</button>
    <a-scene background="color: black">
        <a-assets>

            <!-- Audio files setup for streaming with minimal preload -->
            <audio id="drone1" src="/audio/00001drone.ogg" preload="metadata"></audio>
            <audio id="drone2" src="/audio/00002drone.ogg" preload="metadata"></audio>
            <audio id="drone3" src="/audio/00003drone.ogg" preload="metadata"></audio>
                      <audio id="drone4" src="/audio/00004drone.ogg" preload="metadata"></audio>
            <audio id="drone5" src="/audio/00005drone.ogg" preload="metadata"></audio>
            <audio id="drone6" src="/audio/00006drone.ogg" preload="metadata"></audio>
             <audio id="drone7" src="/audio/00007drone.ogg" preload="metadata"></audio>
            <audio id="drone8" src="/audio/00008drone.ogg" preload="metadata"></audio>
            <audio id="drone9" src="/audio/00009drone.ogg" preload="metadata"></audio>
               <audio id="drone10" src="/audio/00010drone.ogg" preload="metadata"></audio>
      </a-assets>
        <!-- Camera with enhanced movement controls -->
<a-entity camera look-controls flight-controls="speed: 200; acceleration: 200; easing: 5" position="0 1.6 0"></a-entity>
 

<!-- Example Cube -->
    <a-box id="targetCube" position="0 0 -5" depth="1" height="0" width="0" color="none"></a-box>

      <script>

        document.addEventListener('DOMContentLoaded', function() {
    const sceneEl = document.querySelector('a-scene');
    sceneEl.addEventListener('loaded', function() {
        // Once the scene is loaded, setup audio elements
        const audios = document.querySelectorAll('audio');
        audios.forEach(audio => {
            // Ensure the audio metadata is loaded to get the duration
            if (audio.readyState >= 2) {
                setupAudio(audio);
            } else {
                // Wait for metadata to load
                audio.addEventListener('loadedmetadata', () => setupAudio(audio));
            }
        });
    });

    function setupAudio(audio) {
        const duration = audio.duration;
        const randomStart = Math.random() * duration;
        audio.currentTime = randomStart; // Set the start time at a random point
        audio.loop = true; // Enable looping
        audio.play(); // Start playback
    }
           document.addEventListener('DOMContentLoaded', function() {
            const cameraEl = document.querySelector('[camera]');
            const cubeEl = document.getElementById('targetCube');

            // Calculate a position for the camera: This positions the camera 10 units away from the cube, directly in front of it.
            let cubePos = cubeEl.object3D.position;
            let offset = new THREE.Vector3(0, 0, 10);  // You can adjust this vector to change the distance and angle.
            let cameraPos = cubePos.clone().add(offset);

            // Set the camera's position and orient it to look at the cube
            cameraEl.setAttribute('position', cameraPos);
            cameraEl.setAttribute('look-at', `#${cubeEl.id}`);
        });
    </script>

   </a-scene>

    <script>
        document.getElementById('startButton').addEventListener('click', function () {
            var sceneEl = document.querySelector('a-scene');
            for (let i = 1; i <= 10; i++) {
                // Calculate spherical coordinates for each drone
                let phi = Math.acos(2 * (i / 10) - 1) - Math.PI / 2;
                let theta = Math.sqrt(10 * Math.PI) * phi;
                let x = Math.cos(theta) * Math.cos(phi) * 3;
                let y = Math.sin(phi) * 3;
                let z = Math.sin(theta) * Math.cos(phi) * 3;
                let audioId = `drone${i}`;

                let audioEl = document.getElementById(audioId);
                if (!audioEl.src) {
                    audioEl.src = `/audio/0000${i.toString().padStart(2, '0')}drone.ogg`;
                    audioEl.load();
                }

                let entityEl = document.createElement('a-entity');
                entityEl.setAttribute('position', `${x} ${y} ${z}`);
                entityEl.setAttribute('sound', `src: #${audioId}; autoplay: true; positional: true; refDistance: 1; rolloffFactor: 1.5; loop: true;`);

                let boxEl = document.createElement('a-box');
                boxEl.setAttribute('position', '0 0 0');
                boxEl.setAttribute('color', 'white');
                boxEl.setAttribute('opacity', '0.5');
                boxEl.setAttribute('material', 'wireframe: true');
                boxEl.setAttribute('depth', '0.5');
                boxEl.setAttribute('height', '0.5');
                boxEl.setAttribute('width', '0.5');
                entityEl.appendChild(boxEl);

                sceneEl.appendChild(entityEl);
            }
        });
    </script>
</body>
</html>